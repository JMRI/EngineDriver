        <item name="reusable_button_corner_radius">@dimen/button_corner_radius_muted</item>

        <!-- include these two for light coloured themes -->
        <item name="android:windowTitleBackgroundStyle">@style/intro_window_title_background_style</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

        <item name="preferenceTheme">@style/app_theme_muted_preferences</item>

<!--        <item name="android:actionBarStyle">@style/actionBarStyle_black</item>-->

        <item name="reusable_popup_background_color">@color/muted</item>

        <item name="reusable_dialog_background_color">@color/muted_light</item>
        <item name="ed_dialog_secondary_background_color">@color/muted</item>
        <item name="reusable_dialog_text_color">@color/muted_sepia</item>
        <item name="reusable_dialog_button_text_color">@color/muted_sepia</item>
        <item name="reusable_dialog_button_background_color">@color/muted_green</item>

        <!-- not sure where this is used -->
        <item name="android:itemBackground">#ff000000</item>

        <!-- underline under Edit Text -->
        <item name="colorControlActivated">@color/muted_very_dark</item>
        <item name="edit_text_underline_activated">@color/muted_very_dark</item>

    </style>


    <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
    <!-- Preferences Theme. Used by the 'muted' theme. Appears as 'Paper' -->
    <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

    <style name="app_theme_muted_preferences" parent="@style/app_theme_muted">
        <item name="android:windowBackground">@drawable/reusable_app_background</item>

        <item name="android:divider">@drawable/reusable_divider</item>
        <item name="android:listDivider">@drawable/reusable_divider</item>

        <item name="android:listSeparatorTextViewStyle">@style/preference_heading_style_reusable</item>

        <item name="editTextPreferenceStyle">@style/Preference.DialogPreference.EditTextPreference</item>

        <item name="colorBackgroundFloating">@color/grey_very_dark</item>

        <item name="reusable_preference_heading_text_color">@color/muted_mega_dark</item>
        <item name="reusable_preference_heading_background_color">@color/muted_dark</item>
        <item name="colorAccent">@color/muted_sepia_dark</item>

    </style>

</resources>