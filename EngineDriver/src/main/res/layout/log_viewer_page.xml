<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true" >

    <include layout="@layout/toolbar_screen_name_line" />
    <include layout="@layout/toolbar" />
    <include layout="@layout/toolbar_status_line" />

    <LinearLayout
        android:id="@+id/logviewer_screen"
        android:layout_width="match_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <ListView
            android:id="@android:id/list"
            style="?attr/EDListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:transcriptMode="normal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/logviewer_button_save"
                style="?attr/ed_normal_button_condensed_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:drawablePadding="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_margin="2dp"
                android:text="@string/logviewerSave"
                android:textSize="12sp"
                app:drawableStartCompat="?attr/ed_write_glyph"
                tools:ignore="RtlSymmetry, RtlHardcoded" />

            <Button
                android:id="@+id/logviewer_button_stop_save"
                style="?attr/ed_normal_button_condensed_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:drawablePadding="0dp"
                android:layout_margin="2dp"
                android:padding="1dp"
                android:text="@string/logviewerStopSave"
                android:textSize="12sp"
                app:drawableStartCompat="?attr/ed_write_off_glyph"
                tools:ignore="RtlSymmetry, RtlHardcoded" />

            <Button
                android:id="@+id/logviewer_button_share"
                style="?attr/ed_normal_button_condensed_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:drawablePadding="0dp"
                android:layout_margin="2dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"

                android:text="@string/logviewerShare"
                android:textSize="12sp"
                app:drawableStartCompat="?attr/ed_share_glyph"
                tools:ignore="RtlHardcoded" />

<!--            <TextView-->
<!--                android:id="@+id/logviewer_info"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_gravity="left"-->
<!--                android:text=""-->
<!--                android:visibility="gone"-->
<!--                style="?attr/list_extras_style"-->
<!--                android:textSize="10sp"-->
<!--                tools:ignore="HardcodedText,RtlHardcoded,SmallSp" />-->

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Button
                android:id="@+id/logviewer_button_close"
                style="?attr/ed_normal_button_condensed_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:text="@string/logviewerClose"
                android:textSize="12sp"
                android:drawablePadding="0dp"
                app:drawableStartCompat="?attr/ed_cross_glyph"
                tools:ignore="RtlHardcoded" />

        </LinearLayout>

    </LinearLayout>
</LinearLayout>