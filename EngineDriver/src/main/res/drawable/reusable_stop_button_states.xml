<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" >

    <item android:state_enabled="false">
        <shape android:shape="rectangle"  >
            <corners android:radius="@dimen/buttonStopCornerRadius_neon" />
            <stroke
                android:width="@dimen/buttonStopDisabledStroke_neon"
                android:color="?attr/reusable_button_disabled_stroke_color" />
            <solid android:color="?attr/reusable_button_disabled_fill_color" />
        </shape>
    </item>

    <item
        android:state_pressed="true"
        android:drawable="@drawable/reusable_button_stop_layers_selected">
    </item>

    <item
        android:state_selected="true"
        android:drawable="@drawable/reusable_button_stop_layers_selected">
    </item>

    <item
        android:drawable="@drawable/reusable_button_stop_layers_enabled">
    </item>

</selector>