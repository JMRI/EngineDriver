    <item android:gravity="bottom"
        android:top="40dip" android:left="17dip"
        android:bottom="3dip" android:right="16dip"
        tools:targetApi="m">
        <shape android:shape="rectangle">
            <corners
                android:radius="3dip" />
            <size
                android:width="30dip"
                android:height="5dip" />
            <solid
                android:color="?attr/reusable_button_active_light_bar_color" />
        </shape>
    </item>

</layer-list>