<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">


    <item
        android:top="0px" android:left="0px"
        android:right="0px" android:bottom="0px">
        <shape android:shape="rectangle"  >
            <corners android:radius="?attr/reusable_button_corner_radius" />
            <stroke
                android:width="2px"
                android:color="?attr/reusable_button_edge_dark_color" />
            <solid android:color="@color/transparent" />
        </shape>
    </item>

    <item
        android:top="3px" android:left="3px"
        android:right="1px" android:bottom="1px">
        <shape android:shape="rectangle"  >
            <corners android:radius="?attr/reusable_button_corner_radius" />
            <stroke
                android:width="2px"
                android:color="?attr/reusable_button_edge_light_color" />
            <solid android:color="@color/transparent" />
        </shape>
    </item>

    <item
        android:top="3px" android:left="3px"
        android:right="0px" android:bottom="0px">
        <shape android:shape="rectangle"  >
            <corners android:radius="?attr/reusable_button_corner_radius" />
            <stroke
                android:width="2px"
                android:color="?attr/reusable_button_edge_highlight_color" />
            <solid android:color="@color/transparent" />
        </shape>
    </item>

    <item
        android:top="2px" android:left="2px"
        android:right="3px" android:bottom="3px">
        <shape android:shape="rectangle"  >
            <corners android:radius="?attr/reusable_button_corner_radius" />
            <stroke android:width="0px"
                android:color="?attr/reusable_button_edge_dark_color" />
            <gradient
                android:angle="135"
                android:centerX="5%"
                android:startColor="?attr/reusable_button_face_end_color"
                android:centerColor="?attr/reusable_button_face_center_color"
                android:endColor="?attr/reusable_button_face_start_color"
                android:type="linear"
                />
        </shape>
    </item>

