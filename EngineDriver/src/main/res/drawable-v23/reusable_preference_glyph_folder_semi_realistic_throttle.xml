<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:state_enabled="true">

        <layer-list >

            <item android:drawable="@drawable/reusable_preference_glyph_folder_empty" />

            <item
                android:drawable="@drawable/glyph_preference_category_semi_realistic_throttle"
                android:top="20dp"
                android:width="110dp"
                android:height="110dp"
                android:gravity="center" />
        </layer-list>
    </item>


    <item
        android:state_enabled="false">

        <layer-list >

            <item android:drawable="@drawable/reusable_preference_glyph_folder_disabled" />

        </layer-list>
    </item>

</selector>